class Solution {
public:
    vector<int> searchRange(vector<int>& nums, int target) {
        int start=0,end=nums.size()-1,first=-1,last=-1,mid;

        //finding first
        while(start<=end){
            mid= start+(end-start)/2;

            if(nums[mid]==target){
                first=mid;
                end=mid-1;  // we do this to check whether there is another occurence before the  first one
            }
            else if(nums[mid]>target) end=mid-1;
            else start=mid+1;
        }

        // finding last 

        start=0;end=nums.size()-1;
        while(start<=end){
            mid= start+(end-start)/2;

            if(nums[mid]==target){
                last=mid;
                start=mid+1;  // we do this to check whether there is another occurence after the  first last one 
            }
            else if(nums[mid]>target) end=mid-1;
            else start=mid+1;
        }

        vector<int>v;
        v.push_back(first);
        v.push_back(last);
        return v;
        
    }
};
