class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
         int n=nums.size();
         if (n<=2) return n;
         int x=2,y=2;
         while(y<n){
            if(nums[y]==nums[x-2]){
                y++;
            }
            else{
            nums[x]=nums[y];
            x++;
            y++;
            }
         }

         return x;
    }
};
