class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n=nums.size();
        int x=0,k=1,y=1;
        while(y<n){
            if(nums[x]==nums[y]){
                y++;
                continue;
            }
            else {
            nums[x+1]=nums[y];
            y++;
            x++;
            k++;
            }
        }

        return k;
    }
};
