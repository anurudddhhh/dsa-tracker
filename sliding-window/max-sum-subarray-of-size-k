class Solution {
  public:
    int maxSubarraySum(vector<int>& arr, int k) {
        // code here
        int n=arr.size();
        int low=0,sum=0,res=0;
        int high=k-1;
        for(int i=low;i<=high;i++){
            sum +=arr[i];
        }
        
        while(high<n){
            res=max(res,sum);
            low++;
            high++;
            if(high==n) break;
            sum = sum-arr[low-1]+arr[high];
        }
        
        return res;
    }
};
